{
    "extends": "astro/tsconfigs/strict",
    "include": [".astro/types.d.ts", "**/*"],
    "exclude": ["dist"],
    "compilerOptions": {
        "baseUrl": ".",
        "verbatimModuleSyntax": true,
        "paths": {
            "@/*": ["src/*"]
        },
        "jsx": "react-jsx",
        "jsxImportSource": "react"
    }
}
